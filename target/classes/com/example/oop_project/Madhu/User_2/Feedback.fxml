                        <RadioButton fx:id="rating2RadioButton" mnemonicParsing="false" text="2" />
                        <RadioButton fx:id="rating3RadioButton" mnemonicParsing="false" text="3" />
                        <RadioButton fx:id="rating4RadioButton" mnemonicParsing="false" text="4" />
                        <RadioButton fx:id="rating5RadioButton" mnemonicParsing="false" text="5" />
                        <RadioButton fx:id="rating6RadioButton" mnemonicParsing="false" text="6" />
                        <RadioButton fx:id="rating7RadioButton" mnemonicParsing="false" text="7" />
                        <RadioButton fx:id="rating8RadioButton" mnemonicParsing="false" text="8" />
                        <RadioButton fx:id="rating9RadioButton" mnemonicParsing="false" text="9" />
