<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="520.0" prefWidth="850.0" style="-fx-background-color: #EEF2F7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.oop_project.Madhu.User1.ReportTechnicalIssueController">

    <children>
        <VBox layoutX="0" layoutY="0" prefHeight="520" prefWidth="200" spacing="6" style="-fx-background-color: #1E2A3A;">
            <padding><Insets bottom="15" left="10" right="10" top="20" /></padding>

            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="Pilot Panel" />
            <Separator />

            <Button onAction="#assignedFlightsOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Assigned Flights" />
            <Button onAction="#updateStatusOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Update Status" />
            <Button onAction="#submitReportOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Submit Report" />
            <Button onAction="#logFlightHoursOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Log Flight Hours" />
            <Button onAction="#maintenanceHistoryOnActionnButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Maintenance History" />
            <Button onAction="#technicalIssuesOnActionButton" prefWidth="180" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Technical Issues" />
            <Button onAction="#flightHistoryOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Flight History" />
            <Button onAction="#completeFlightOnActionButton" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;" text="Complete Flight" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator />
            <Button onAction="#logoutOnActionButton" prefWidth="180" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 12 8 12;" text="Logout" />
        </VBox>

        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" prefHeight="634.0" prefWidth="650.0" style="-fx-background-color: #EEF2F7; -fx-background: #EEF2F7; -fx-border-color: transparent;" AnchorPane.bottomAnchor="-114.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <VBox spacing="16">
                <padding><Insets bottom="20" left="15" right="20" top="20" /></padding>

                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Report Technical Issue" />

                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 0 0 4 0;" text="Issue Details" />
                    <HBox spacing="10">
                        <Label prefWidth="130" style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Helicopter ID:" />
                        <TextField fx:id="helicopterIdTextField" prefWidth="260" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10 6 10;" />
                    </HBox>
                    <HBox spacing="10">
                        <Label prefWidth="130" style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Issue Title:" />
                        <TextField fx:id="titleTextField" prefWidth="260" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10 6 10;" />
                    </HBox>
                    <HBox spacing="10">
                        <Label prefWidth="130" style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Priority:" />
                        <ComboBox fx:id="priorityComboBox" prefWidth="220" style="-fx-background-radius: 6; -fx-border-radius: 6;" />
                    </HBox>
                    <HBox alignment="TOP_LEFT" spacing="10">
                        <Label prefWidth="130" style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Description:" />
                        <TextArea fx:id="descriptionAreaTextField" prefHeight="100" prefWidth="360" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1;" />
                    </HBox>
                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#submitReportOnActionButton" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;" text="Submit Report" />
                    </HBox>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 0 0 8 0;" text="Previous Reports" />
                    <TableView fx:id="issueTableView" prefHeight="150">
                        <columns>
                            <TableColumn fx:id="helicopterIDTextField" prefWidth="80" text="Helicopter ID" />
                            <TableColumn fx:id="titleTableColumn" prefWidth="150" text="Title" />
                            <TableColumn fx:id="priorityTableColumn" prefWidth="100" text="Priority" />
                            <TableColumn fx:id="statusTableColumn" prefWidth="150" text="Status" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </children>
</AnchorPane>
