<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="520.0" prefWidth="850.0"
            style="-fx-background-color: #EEF2F7;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_project.Madhu.User2.BookingCancelController">

    <children>
        <VBox layoutX="0" layoutY="0" prefWidth="200" prefHeight="520"
              spacing="6" style="-fx-background-color: #1E2A3A;">
            <padding><Insets top="20" left="10" right="10" bottom="15"/></padding>

            <Label text="Client Panel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Separator/>

            <Button prefWidth="180" text="Services" onAction="#servicesOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Search Services" onAction="#searchServicesOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Book Flight" onAction="#bookFlightOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Payments" onAction="#paymentsOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Booking History" onAction="#bookingHistoryOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Flight Status" onAction="#flightStatusOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Cancel Booking" onAction="#cancelBookingOnAction"
                    style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>
            <Button prefWidth="180" text="Feedback" onAction="#feedbackOnAction"
                    style="-fx-background-color: transparent; -fx-text-fill: #CBD5E1; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12 8 12;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Button prefWidth="180" text="Logout" onAction="#logoutOnAction"
                    style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 12 8 12;"/>
        </VBox>

        <ScrollPane fx:id="mainScrollPane"
                    AnchorPane.leftAnchor="200.0" AnchorPane.topAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #EEF2F7; -fx-background: #EEF2F7; -fx-border-color: transparent;">
            <VBox spacing="16">
                <padding><Insets top="20" right="20" bottom="20" left="15"/></padding>
                <Label text="Cancel Booking" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="Select Booking to Cancel" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 0 0 8 0;"/>
                    <TableView fx:id="bookingTable" prefHeight="180">
                        <columns>
                            <TableColumn fx:id="bookingIDColumn" prefWidth="100.0" text="Booking ID" maxWidth="1000.0"
                                         minWidth="30.0"/>
                            <TableColumn fx:id="serviceColumn" prefWidth="140.0" text="Service" maxWidth="1400.0"
                                         minWidth="30.0"/>
                            <TableColumn fx:id="dateColumn" prefWidth="120.0" text="Date" maxWidth="1200.0"
                                         minWidth="30.0"/>
                            <TableColumn fx:id="routeColumn" prefWidth="140.0" text="Route" maxWidth="1400.0"
                                         minWidth="30.0"/>
                            <TableColumn fx:id="statusColumn" prefWidth="94.0" text="Status" maxWidth="940.0"
                                         minWidth="30.0"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="Cancellation Details" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 0 0 4 0;"/>
                    <HBox alignment="TOP_LEFT" spacing="10">
                        <Label prefWidth="100" text="Booking ID:" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        <TextArea fx:id="reasonTextArea" prefHeight="39.0" prefWidth="360"
                                  style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1;"/>
                    </HBox>
                    <HBox alignment="TOP_LEFT" spacing="10">
                        <Label prefWidth="100" text="Reason:" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        <TextArea fx:id="reasonTextArea1" prefHeight="80" prefWidth="360"
                                  style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1;"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Cancel Booking" onAction="#cancelBookingOnAction"
                                style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </children>
</AnchorPane>
