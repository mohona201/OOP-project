<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 30;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.BillingController">
    <Label text="Revenue &amp; Billing Summary" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <HBox spacing="30" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e2e8f0;">
        <VBox>
            <Label text="Total Completed Flights"/>
            <Label fx:id="totalFlights" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        </VBox>
        <VBox>
            <Label text="Total Revenue"/>
            <Label fx:id="totalRevenue" text="$0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
        </VBox>
    </HBox>
    <Button text="Generate Report" onAction="#generateReport" />
</VBox>