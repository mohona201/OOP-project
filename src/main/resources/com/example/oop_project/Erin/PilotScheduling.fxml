<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f4;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.PilotSchedulingController">

    <Label text="Pilot Scheduling Management" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Pilot Name:"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1"/>

        <Label text="License ID:" GridPane.rowIndex="1"/>
        <TextField fx:id="idField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Shift:" GridPane.rowIndex="2"/>
        <ComboBox fx:id="shiftBox" promptText="Select Shift" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Button text="Add Pilot" onAction="#savePilot"
                style="-fx-background-color: #2b5797; -fx-text-fill: white;"
                GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <TableView fx:id="pilotTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="Pilot Name" prefWidth="150" />
            <TableColumn fx:id="colId" text="License ID" prefWidth="100" />
            <TableColumn fx:id="colShift" text="Assigned Shift" prefWidth="150" />
        </columns>
    </TableView>
</VBox>