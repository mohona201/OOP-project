<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #EEF2F7;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FuelController">
    <Label text="Fuel Consumption Analytics" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Helicopter ID:"/>
        <TextField fx:id="fuelHeliId" GridPane.columnIndex="1"/>
        <Label text="Fuel Added (Liters):" GridPane.rowIndex="1"/>
        <TextField fx:id="fuelAmount" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Button text="Log Fueling" onAction="#handleLogFuel" style="-fx-background-color: #059669; -fx-text-fill: white;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>
    <TextArea fx:id="fuelLogArea" prefHeight="200" editable="false"/>
</VBox>