<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f1f5f9;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.HelipadController">

    <Label text="Helipad Status Manager" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Toggle Occupancy" onAction="#toggleStatus"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;"/>
        <Label text="(Select a row to flip status)" style="-fx-text-fill: #64748b; -fx-font-italic: true;"/>
    </HBox>

    <TableView fx:id="helipadTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
        <columns>
            <TableColumn fx:id="colPadName" text="Helipad Name" prefWidth="200" />
            <TableColumn fx:id="colStatus" text="Is Occupied?" prefWidth="150" />
        </columns>
    </TableView>
</VBox>