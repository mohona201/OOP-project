<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="720.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.BDODashboardController">

    <VBox spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 20; -fx-min-width: 250;">
        <Label text="BDO SYSTEM" style="-fx-text-fill: #38bdf8; -fx-font-size: 22; -fx-font-weight: bold;"/>
        <Label text="Dispatch Officer Terminal" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
        <Separator opacity="0.1" style="-fx-padding: 10 0;"/>

        <Label text="OPERATIONS" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-weight: bold;"/>
        <Button text="1. New Booking" onAction="#openBooking" maxWidth="Infinity" styleClass="menu-btn" style="-fx-alignment: BASELINE_LEFT;"/>
        <Button text="2. Flight Dispatch" onAction="#openDispatch" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>
        <Button text="3. Flight Schedule" onAction="#openSchedule" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>
        <Button text="4. Emergency Alert" onAction="#openEmergency" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT; -fx-text-fill: #f87171;"/>

        <Label text="SAFETY &amp; FEEDBACK" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
        <Button text="5. Fuel &amp; Load" onAction="#openFuelLoad" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>
        <Button text="6. User Feedback" onAction="#openFeedback" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>

        <Label text="REPORTS" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
        <Button text="7. Flight Logs" onAction="#openLogs" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>
        <Button text="8. Billing/Revenue" onAction="#openBilling" maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;"/>

        <Region VBox.vgrow="ALWAYS" />
        <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f1f5f9;">
        <VBox fx:id="contentArea" VBox.vgrow="ALWAYS" alignment="CENTER" style="-fx-padding: 30;">
            <Label text="System Ready" style="-fx-text-fill: #1e293b; -fx-font-size: 28; -fx-font-weight: bold;"/>
            <Label text="Select an operational goal from the sidebar to continue." style="-fx-text-fill: #64748b; -fx-font-size: 16;"/>
        </VBox>

        <HBox style="-fx-background-color: #ffffff; -fx-padding: 5 15; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <Label text="Database: Connected (FlightData.bin)" style="-fx-text-fill: #10b981; -fx-font-size: 11;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="BDO Session: Active" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </HBox>
    </VBox>
</HBox>