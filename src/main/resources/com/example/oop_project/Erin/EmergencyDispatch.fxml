<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25; -fx-background-color: #fef2f2;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.EmergencyDispatchController">

    <Label text="⚠ Emergency Priority Dispatch" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Select Flight to Escalate:"/>
        <ComboBox fx:id="flightSelector" prefWidth="200" promptText="Choose Flight ID"/>
        <Button text="DECLARE EMERGENCY" onAction="#handleEmergency"
                style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TextArea fx:id="incidentArea" promptText="Enter nature of emergency (e.g., Medical, Low Fuel, Engine Warning)..."
              prefHeight="150" wrapText="true"/>

    <Label fx:id="alertLabel" style="-fx-text-fill: #b91c1c; -fx-font-weight: bold;"/>
</VBox>