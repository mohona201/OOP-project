<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #EEF2F7;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.WeatherRiskController">

    <Label text="Weather Risk Assessment" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <GridPane hgap="15" vgap="15">
        <Label text="Visibility (km):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="visibilityField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Wind Speed (knots):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="windSpeedField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Button text="Analyze Risk" onAction="#handleCheckWeather"
                style="-fx-background-color: #2563EB; -fx-text-fill: white;"
                GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <TextArea fx:id="resultArea" editable="false" prefHeight="150" promptText="Analysis result will appear here..."/>
</VBox>