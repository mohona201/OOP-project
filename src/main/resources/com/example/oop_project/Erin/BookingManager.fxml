<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: white;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.BookingManagerController">

    <Label text="New Flight Booking" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

    <GridPane hgap="15" vgap="15">
        <Label text="Passenger Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter full name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Destination:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="destField" promptText="e.g. Sylhet, Chittagong" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Helicopter ID:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="heliField" promptText="H-101" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Button text="Confirm Booking" onAction="#saveBooking"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="statusLabel" style="-fx-text-fill: #059669; -fx-font-weight: bold;"/>
</VBox>