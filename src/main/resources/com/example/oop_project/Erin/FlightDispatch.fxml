<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FlightDispatchController">

    <Label text="Flight Dispatch Queue" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <TableView fx:id="dispatchTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Flight ID" prefWidth="100"/>
            <TableColumn fx:id="colPassenger" text="Passenger" prefWidth="150"/>
            <TableColumn fx:id="colDest" text="Destination" prefWidth="120"/>
            <TableColumn fx:id="colStatus" text="Current Status" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Set as DISPATCHED" onAction="#dispatchFlight"
                style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Cancel Flight" onAction="#cancelFlight"
                style="-fx-background-color: #dc2626; -fx-text-fill: white;"/>
    </HBox>
</VBox>