<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f8fafc;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FleetMaintenanceController">

    <Label text="Fleet Maintenance Logs" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="heliIdField" promptText="Helicopter ID" prefWidth="120"/>
        <ComboBox fx:id="statusCombo" promptText="Status" prefWidth="150"/>
        <TextField fx:id="dateField" promptText="Date (YYYY-MM-DD)" prefWidth="150"/>
        <Button text="Add Record" onAction="#handleAddRecord"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="maintenanceTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colHeliId" text="Heli ID" prefWidth="120" />
            <TableColumn fx:id="colStatus" text="Maintenance Status" prefWidth="180" />
            <TableColumn fx:id="colDate" text="Last Service" prefWidth="150" />
        </columns>
    </TableView>
</VBox>