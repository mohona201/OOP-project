<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FuelLoadController">
    <Label text="Pre-Flight Weight &amp; Fuel Check" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Passenger Weight (kg):" GridPane.rowIndex="0"/>
        <TextField fx:id="passWeight" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Cargo Weight (kg):" GridPane.rowIndex="1"/>
        <TextField fx:id="cargoWeight" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Fuel Needed (Liters):" GridPane.rowIndex="2"/>
        <TextField fx:id="fuelAmount" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Button text="Calculate Total" onAction="#calculateLoad" style="-fx-background-color: #2563eb; -fx-text-fill: white;"
                GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="resultLabel" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
</VBox>