<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FlightScheduleController">
    <Label text="Flight Schedule Overview" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Search by Flight ID or Dest..." prefWidth="250"/>
        <Button text="Filter" onAction="#handleFilter" />
    </HBox>
    <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colTime" text="Departure Time" prefWidth="150"/>
            <TableColumn fx:id="colDest" text="Destination" prefWidth="150"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>