<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.helicopter_service.Erin.fom.FeedbackController">
    <Label text="Customer Feedback Entry" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
    <TextField fx:id="customerName" promptText="Customer Name"/>
    <Slider fx:id="ratingSlider" min="1" max="5" showTickLabels="true" showTickMarks="true"/>
    <TextArea fx:id="commentArea" promptText="Comments..." prefHeight="100"/>
    <Button text="Submit Review" onAction="#saveFeedback" style="-fx-background-color: #059669; -fx-text-fill: white;"/>
</VBox>