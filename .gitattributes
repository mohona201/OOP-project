# Normalize line endings to LF in the repo, checkout as native on each OS
* text=auto

# Force LF for Java and XML source files on all platforms
*.java text eol=lf
*.fxml text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.properties text eol=lf

# Binary files - never convert
*.bin  binary
*.class binary
*.jar  binary
*.png  binary
*.jpg  binary
*.ico  binary
